<!DOCTYPE html>
<html>
<head>
    <title>我的第一个网页游戏</title>
    <style>
        body { text-align: center; background: #222; color: white; font-family: sans-serif; }
        canvas { background: #000; display: block; margin: 20px auto; border: 2px solid #fff; cursor: none; }
    </style>
</head>
<body>
    <h1>接球小游戏</h1>
    <p>用鼠标移动挡板，别让小球掉下去！</p>
    <canvas id="gameCanvas" width="400" height="400"></canvas>

    <script>
        const canvas = document.getElementById("gameCanvas");
        const ctx = canvas.getContext("2d");

        let ballX = 200, ballY = 50, ballDX = 2, ballDY = 2;
        let paddleX = 150;
        const paddleWidth = 100, paddleHeight = 10;

        // 监听鼠标移动
        canvas.addEventListener("mousemove", (e) => {
            paddleX = e.clientX - canvas.offsetLeft - paddleWidth / 2;
        });

        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            // 绘制小球
            ctx.fillStyle = "white";
            ctx.beginPath();
            ctx.arc(ballX, ballY, 10, 0, Math.PI * 2);
            ctx.fill();

            // 绘制挡板
            ctx.fillStyle = "#00ffcc";
            ctx.fillRect(paddleX, 380, paddleWidth, paddleHeight);

            // 小球移动逻辑
            ballX += ballDX;
            ballY += ballDY;

            // 碰到墙壁反弹
            if (ballX < 10 || ballX > 390) ballDX = -ballDX;
            if (ballY < 10) ballDY = -ballDY;

            // 碰到挡板反弹
            if (ballY > 370 && ballX > paddleX && ballX < paddleX + paddleWidth) {
                ballDY = -ballDY;
            }

            // 掉到底部游戏结束
            if (ballY > 400) {
                alert("游戏结束！");
                ballX = 200; ballY = 50;
            }

            requestAnimationFrame(draw);
        }
        draw();
    </script>
</body>
</html>
